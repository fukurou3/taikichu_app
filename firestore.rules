rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==============================================
    // 🚨 Phase 0 完了: クライアント直接アクセス完全禁止
    // 全てのデータアクセスは統一パイプライン経由
    // ==============================================
    match /{document=**} {
      allow read: if false; // クライアントからの読み取り完全禁止
      allow write: if false; // クライアントからの書き込み完全禁止
    }

    // ==============================================
    // ヘルパー関数定義
    // ==============================================
    
    /// 認証済みユーザーチェック
    function isAuthenticated() {
      return request.auth != null && 
             request.auth.uid != null && 
             request.auth.uid != '';
    }
    
    /// データ所有者チェック
    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    /// Cloud Functions/Cloud Run サービスアカウント認証チェック
    function isServiceAccount() {
      return request.auth != null && (
        // Firebase Admin SDK
        request.auth.token.firebase.sign_in_provider == 'custom' ||
        
        // Cloud Functions/Cloud Run からの呼び出し
        request.auth.uid.matches('firebase-adminsdk.*') ||
        
        // Google Cloud サービスアカウント
        request.auth.token.firebase.identities.keys().hasAny(['google.com']) &&
        request.auth.token.email.matches('.*@.*\\.iam\\.gserviceaccount\\.com')
      );
    }

    // ==============================================
    // 🔒 システム専用コレクション（サービスアカウントのみ）
    // ==============================================

    /// counts - カウントダウン集計データ
    /// ❌ クライアントからの直接アクセス完全禁止
    match /counts/{countdownId} {
      allow read: if isServiceAccount(); // サービスアカウントのみ読み取り可能
      allow write: if isServiceAccount(); // サービスアカウントのみ書き込み可能
    }

    /// trendRankings - トレンドランキング集計データ
    /// ❌ クライアントからの直接アクセス完全禁止
    match /trendRankings/{rankingId} {
      allow read: if isServiceAccount(); // サービスアカウントのみ読み取り可能
      allow write: if isServiceAccount(); // サービスアカウントのみ書き込み可能
    }

    /// distributed_counters - 分散カウンター
    /// ❌ クライアントからの直接書き込み完全禁止
    match /distributed_counters/{counterId} {
      allow read: if isServiceAccount(); // サービスアカウントのみ読み取り可能
      allow write: if isServiceAccount(); // サービスアカウントのみ書き込み可能
    }

    /// countdownShards - 分散カウンターシャード
    /// ❌ クライアントからの直接書き込み完全禁止
    match /countdownShards/{shardId} {
      allow read: if isServiceAccount(); // サービスアカウントのみ読み取り可能
      allow write: if isServiceAccount(); // サービスアカウントのみ書き込み可能
    }

    // ==============================================
    // 📝 コンテンツコレクション（サービスアカウントのみ）
    // ==============================================

    /// countdowns - カウントダウン本体
    /// ❌ クライアントからの直接アクセス完全禁止
    match /countdowns/{countdownId} {
      allow read: if isServiceAccount(); // サービスアカウントのみ読み取り可能
      allow write: if isServiceAccount(); // サービスアカウントのみ書き込み可能
    }

    /// comments - コメント
    /// ❌ クライアントからの直接アクセス完全禁止
    match /comments/{commentId} {
      allow read: if isServiceAccount(); // サービスアカウントのみ読み取り可能
      allow write: if isServiceAccount(); // サービスアカウントのみ書き込み可能
    }

    // ==============================================
    // 👍 エンゲージメントコレクション（サービスアカウントのみ）
    // ==============================================

    /// likes - いいね
    /// ❌ クライアントからの直接アクセス完全禁止
    match /likes/{likeId} {
      allow read: if isServiceAccount(); // サービスアカウントのみ読み取り可能
      allow write: if isServiceAccount(); // サービスアカウントのみ書き込み可能
    }

    /// participants - 参加者
    /// ❌ クライアントからの直接アクセス完全禁止
    match /participants/{participantId} {
      allow read: if isServiceAccount(); // サービスアカウントのみ読み取り可能
      allow write: if isServiceAccount(); // サービスアカウントのみ書き込み可能
    }

    // ==============================================
    // 👤 ユーザー関連コレクション（所有者のみ編集可能）
    // ==============================================

    /// users - ユーザープロフィール
    /// ✅ 本人のみ編集可能（例外的に許可）
    match /users/{userId} {
      allow read: if isAuthenticated(); // 認証済みユーザーは読み取り可能
      allow create: if isOwner(userId) && 
                       request.resource.data.createdAt == request.time;
      allow update: if isOwner(userId) && 
                       request.resource.data.updatedAt == request.time;
      allow delete: if isOwner(userId);
    }

    /// notifications - 通知
    /// ✅ 本人のみ読み取り・更新、作成はサービスアカウントのみ
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && 
                     request.auth.uid == resource.data.userId;
      allow create: if isServiceAccount();
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ==============================================
    // 🔒 システム専用コレクション
    // ==============================================

    /// analytics - システム分析データ
    /// ❌ サービスアカウントのみアクセス可能
    match /analytics/{document} {
      allow read: if isServiceAccount();
      allow write: if isServiceAccount();
    }

    /// system_logs - システムログ
    /// ❌ サービスアカウントのみアクセス可能
    match /system_logs/{logId} {
      allow read: if isServiceAccount();
      allow write: if isServiceAccount();
    }

    /// admin_settings - 管理者設定
    /// ❌ サービスアカウントのみアクセス可能
    match /admin_settings/{settingId} {
      allow read: if isServiceAccount();
      allow write: if isServiceAccount();
    }
  }
}

/*
==============================================
🛡️ セキュリティポリシー概要
==============================================

1. ゼロトラスト原則
   - デフォルトは全ての書き込みを拒否
   - 明示的な許可のみ

2. 統一パイプライン強制
   - counts, likes, participants等はサービスアカウントのみ
   - クライアントからの直接書き込み完全禁止

3. 所有者制限
   - ユーザーは自分のプロフィールのみ操作可能
   - 他人のデータは読み取りのみ

4. サービスアカウント検証
   - Firebase Admin SDK
   - Cloud Functions/Cloud Run
   - Google Cloud サービスアカウント

==============================================
🚀 運用時の注意事項
==============================================

1. 全てのデータ更新はUnifiedAnalyticsService経由
2. クライアントはイベント発行のみ
3. データベース更新はバックエンドの責務
4. 緊急時はルールを一時的に更に厳格化可能

==============================================
*/
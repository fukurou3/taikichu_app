# 🔧 環境変数テンプレート
# =============================================
# 
# 📋 セットアップ手順:
# 1. このファイルを .env.development にコピー
# 2. 必要な値を入力
# 3. service-account.json をプロジェクトルートに配置
#
# cp .env.example .env.development

# ============================================
# 🎯 プロジェクト基本設定
# ============================================
PROJECT_ID=your-firebase-project-id
ENVIRONMENT=development
DEBUG=true

# ============================================
# 🔐 認証設定 (ローカルパスを指定)
# ============================================
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ============================================
# 🐳 Docker サービス設定
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

ANALYTICS_SERVICE_HOST=localhost
ANALYTICS_SERVICE_PORT=8080

PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=your-firebase-project-id

# ============================================
# 🔥 Firebase Emulator 設定
# ============================================
FIRESTORE_EMULATOR_HOST=localhost:8000
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_FUNCTIONS_EMULATOR_HOST=localhost:5001
FIREBASE_UI_HOST=localhost:4000

# ============================================
# 📱 Flutter アプリケーション設定
# ============================================
FLUTTER_ENVIRONMENT=development
ENABLE_FIREBASE_EMULATOR=true
ENABLE_DEBUG_LOGGING=true

# ============================================
# 🚀 統一パイプライン設定
# ============================================
UNIFIED_ANALYTICS_ENDPOINT=http://localhost:8080
ENABLE_MOCK_DATA=true
CACHE_DURATION_SECONDS=300

# ============================================
# 🧪 テスト・デバッグ設定
# ============================================
ENABLE_PERFORMANCE_MONITORING=true
LOG_LEVEL=DEBUG
MOCK_USER_ID=test_user_development
ENABLE_ANALYTICS_LOGGING=true

# ============================================
# 📊 メトリクス・監視設定
# ============================================
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL=30
METRICS_COLLECTION_ENABLED=true
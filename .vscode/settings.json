{
  "// 🚀 Taikichu App - VS Code プロジェクト設定": "",
  "// ===============================================": "",
  
  "// 🎨 エディター設定": "",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.rulers": [80, 120],
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 120,
  
  "// 📱 Dart/Flutter設定": "",
  "dart.flutterSdkPaths": [],
  "dart.lineLength": 120,
  "dart.insertArgumentPlaceholders": false,
  "dart.previewFlutterUiGuides": true,
  "dart.previewFlutterUiGuidesCustomTracking": true,
  "dart.hotReloadOnSave": "allIfDirty",
  "dart.debugExternalPackageLibraries": false,
  "dart.debugSdkLibraries": false,
  
  "// 🐳 Docker設定": "",
  "docker.defaultRegistryPath": "",
  
  "// 🔥 Firebase設定": "",
  "firebase.hosting.automaticallyOpenBrowser": false,
  
  "// 📂 ファイル関連設定": "",
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/.dart_tool": true,
    "**/build": true,
    "**/*.log": true,
    "service-account.json": true,
    ".env.development": true
  },
  
  "// 🔍 検索設定": "",
  "search.exclude": {
    "**/node_modules": true,
    "**/.dart_tool": true,
    "**/build": true,
    "**/*.log": true,
    "**/migration_*.log": true,
    "**/.firebase": true
  },
  
  "// 📝 言語別設定": "",
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off"
  },
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[dockerfile]": {
    "editor.formatOnSave": true
  },
  
  "// 🧪 テスト設定": "",
  "dart.testInvocation": "flutter",
  "flutter.testOutputDirectory": "./test-results",
  
  "// 🔗 統合ターミナル設定": "",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "args": ["-NoExit", "-Command", "Write-Host '🐳 Taikichu App 開発環境' -ForegroundColor Cyan"]
    }
  },
  
  "// 🎯 推奨設定": "",
  "workbench.colorTheme": "Default Dark+",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "readme",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  
  "// 📊 Git設定": "",
  "git.autofetch": true,
  "git.enableCommitSigning": false,
  "git.confirmSync": false,
  
  "// 🔧 その他": "",
  "telemetry.telemetryLevel": "off",
  "update.showReleaseNotes": false,
  "extensions.ignoreRecommendations": false
}